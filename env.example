# 复制为 .env 后按需填写（本地测试或服务器 source .env）

# 数据获取模式: git | remote | local
SYNC_MODE=git

# MetaMetadata 源
METADATA_REPO=https://github.com/threethan/MetaMetadata.git
METADATA_RAW=https://raw.githubusercontent.com/threethan/MetaMetadata/main
METADATA_DIR=.cache/metmetadata

# 图标输出
ICON_DIR=icons
MAX_WORKERS=8

# 上传方式: 留空=不上传 | copy=复制到本地目录 | sftp=SFTP上传
UPLOAD_METHOD=

# copy 模式
DEPLOY_PATH=/var/www/html/icons

# sftp 模式
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
SFTP_KEY_PATH=
SFTP_REMOTE_DIR=/var/www/icons
