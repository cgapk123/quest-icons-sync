      "review_helpful_count": 3,
      "author_display_name": "Joelartdesigns.IG",
      "author_alias": "Joelartdesigns.IG",
      "developer_response": {
        "body": "Thanks for the feedback, and sorry you had a bad experience! For the fire, if it’s on a furniture, try breaking the furniture first and then putting out the flames. Also, we  appreciate your suggestion to add more mass to the axe, we’ll be looking into it. Stay tuned, we’ve got a lot of new levels coming soon!",
        "date": 1767957608
      }
