      "review_helpful_count": 36,
      "author_display_name": "Khabib544",
      "author_alias": "Khabib544",
      "developer_response": {
        "body": "Thank you for the support and for taking the time to share this. You make a very fair point about the game becoming repetitive. We've noted your mission suggestion for future consideration. Feedback like this is invaluable to us, thanks again for helping us improve the game!",
        "date": 1776909531
      }
    },
